{
  "name": "hackathon-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "supabase:login": "npx supabase login",
    "supabase:link": "npx supabase link",
    "db:migration:new": "npx supabase migration new",
    "db:migration:up": "npx supabase migration up",
    "db:push": "npx supabase db push",
    "db:push:remote": "npx supabase db push --linked",
    "db:pull": "npx supabase db pull",
    "db:reset": "npx supabase db reset",
    "db:seed": "npx supabase db reset --local",
    "db:seed:remote": "npx supabase db push --include-seed",
    "db:types": "npx supabase gen types typescript --linked > src/types/database.generated.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "next": "^16.1.6",
    "nodemailer": "^8.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "typescript": "^5.9.3"
  }
}
