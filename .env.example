NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional: comma-separated model choices shown in Ask AI model selector
# Example: gpt-4.1-mini,gpt-4.1,gpt-5-mini,gpt-5
OPENAI_ASK_AI_MODELS=gpt-4.1-mini,gpt-4.1,gpt-5-mini,gpt-5

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP (Custom mail delivery for auth emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM="Nference Research OS <your-email@gmail.com>"
